// Prisma Schema for Property Portfolio Management System
// Domain model: Person (mortgages/tenants), Owner (property ownership), Property, Ownership, Mortgage, RentalAgreement, PropertyEvent

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User (Authentication & Authorization)
// ============================================

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  googleId    String?   @unique @map("google_id")
  name        String?
  picture     String?
  role        UserRole  @default(MEMBER)
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@index([googleId])
  @@map("users")
}

enum UserRole {
  ADMIN
  MEMBER
}

// ============================================
// Person (Universal entity: individuals, companies, tenants, owners, etc.)
// ============================================

model Person {
  id       String     @id @default(uuid())
  name     String
  type     PersonType @default(INDIVIDUAL)
  idNumber String?    @map("id_number")
  email    String?
  phone    String?
  address  String?
  notes    String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  mortgageOwnerOf Mortgage[]        @relation("MortgageOwner")
  mortgagePayerOf Mortgage[]        @relation("MortgagePayer")
  tenantsOf       RentalAgreement[] @relation("RentalTenant")
  ownershipsOf    Ownership[]

  @@index([name])
  @@index([type])
  @@index([deletedAt])
  @@map("persons")
}

enum PersonType {
  INDIVIDUAL
  COMPANY
  PARTNERSHIP
}

// ============================================
// Bank Accounts
// ============================================

model BankAccount {
  id            String          @id @default(uuid())
  bankName      String          @map("bank_name")
  branchNumber  String?         @map("branch_number")
  accountNumber String          @map("account_number")
  accountType   BankAccountType @map("account_type") @default(PERSONAL_CHECKING)
  accountHolder String?         @map("account_holder")
  notes         String?
  isActive      Boolean         @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  mortgages            Mortgage[]
  propertyEventsPaidTo PropertyEvent[]

  @@unique([bankName, accountNumber])
  @@index([bankName])
  @@index([deletedAt])
  @@map("bank_accounts")
}

enum BankAccountType {
  TRUST_ACCOUNT
  PERSONAL_CHECKING
  PERSONAL_SAVINGS
  BUSINESS
}

// ============================================
// Properties
// ============================================

model Property {
  id         String  @id @default(uuid())
  address    String
  fileNumber String? @map("file_number")

  // Property classification
  type              PropertyType?
  status            PropertyStatus? @default(OWNED)
  country           String          @default("Israel")
  city              String?
  totalArea         Decimal?        @map("total_area") @db.Decimal(10, 2)
  landArea          Decimal?        @map("land_area") @db.Decimal(10, 2)
  estimatedValue    Decimal?        @map("estimated_value") @db.Decimal(12, 2)
  lastValuationDate DateTime?       @map("last_valuation_date")

  // Plot/land registry
  gush        String?
  helka       String?
  isMortgaged Boolean @default(false) @map("is_mortgaged")

  // Area & Dimensions
  floors         Int?         @map("floors")
  totalUnits     Int?         @map("total_units")
  parkingSpaces  Int?         @map("parking_spaces")
  balconySizeSqm Decimal?     @map("balcony_size_sqm") @db.Decimal(6, 2)
  storageSizeSqm Decimal?     @map("storage_size_sqm") @db.Decimal(6, 2)
  parkingType    ParkingType? @map("parking_type")

  // Financial
  purchasePrice     Decimal?           @map("purchase_price") @db.Decimal(12, 2)
  purchaseDate      DateTime?          @map("purchase_date")
  acquisitionMethod AcquisitionMethod? @map("acquisition_method")
  estimatedRent     Decimal?           @map("estimated_rent") @db.Decimal(10, 2)
  rentalIncome      Decimal?           @map("rental_income") @db.Decimal(10, 2)
  projectedValue    Decimal?           @map("projected_value") @db.Decimal(12, 2)
  saleProjectedTax  Decimal?           @map("sale_projected_tax") @db.Decimal(12, 2)

  // Legal & Registry
  cadastralNumber  String?      @map("cadastral_number")
  taxId            String?      @map("tax_id")
  registrationDate DateTime?    @map("registration_date")
  legalStatus      LegalStatus? @map("legal_status")

  // Property Details
  constructionYear     Int?               @map("construction_year")
  lastRenovationYear   Int?               @map("last_renovation_year")
  buildingPermitNumber String?            @map("building_permit_number")
  propertyCondition    PropertyCondition? @map("property_condition")

  // Land Information
  landType        LandType? @map("land_type")
  landDesignation String?   @map("land_designation")

  // Ownership
  isPartialOwnership        Boolean  @default(false) @map("is_partial_ownership")
  sharedOwnershipPercentage Decimal? @map("shared_ownership_percentage") @db.Decimal(5, 2)

  // Sale Information
  isSold    Boolean   @default(false) @map("is_sold")
  saleDate  DateTime? @map("sale_date")
  salePrice Decimal?  @map("sale_price") @db.Decimal(12, 2)

  // Management
  propertyManager        String?                 @map("property_manager")
  managementCompany      String?                 @map("management_company")
  managementFees         Decimal?                @map("management_fees") @db.Decimal(10, 2)
  managementFeeFrequency ManagementFeeFrequency? @map("management_fee_frequency")

  // Financial Obligations
  taxAmount      Decimal?      @map("tax_amount") @db.Decimal(10, 2)
  taxFrequency   TaxFrequency? @map("tax_frequency")
  lastTaxPayment DateTime?     @map("last_tax_payment")

  // Insurance
  insuranceDetails String?   @map("insurance_details")
  insuranceExpiry  DateTime? @map("insurance_expiry")

  // Utilities & Infrastructure
  zoning       String?
  utilities    String?
  restrictions String?

  // Valuation
  estimationSource EstimationSource? @map("estimation_source")

  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  planningProcessState PlanningProcessState?
  utilityInfo          UtilityInfo?
  ownerships           Ownership[]
  mortgages            Mortgage[]
  rentalAgreements     RentalAgreement[]
  propertyEvents       PropertyEvent[]

  @@index([type])
  @@index([status])
  @@index([country])
  @@index([city])
  @@index([isMortgaged])
  @@index([isPartialOwnership])
  @@index([isSold])
  @@index([deletedAt])
  @@map("properties")
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  LAND
  MIXED_USE
}

enum PropertyStatus {
  OWNED
  IN_CONSTRUCTION
  IN_PURCHASE
  SOLD
  INVESTMENT
}

enum ParkingType {
  REGULAR
  CONSECUTIVE
}

enum AcquisitionMethod {
  PURCHASE
  INHERITANCE
  GIFT
  EXCHANGE
  OTHER
}

enum LegalStatus {
  REGISTERED
  IN_REGISTRATION
  DISPUTED
  CLEAR
}

enum PropertyCondition {
  EXCELLENT
  GOOD
  FAIR
  NEEDS_RENOVATION
}

enum LandType {
  URBAN
  AGRICULTURAL
  INDUSTRIAL
  MIXED
}

enum ManagementFeeFrequency {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum TaxFrequency {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum EstimationSource {
  PROFESSIONAL_APPRAISAL
  MARKET_ESTIMATE
  TAX_ASSESSMENT
  OWNER_ESTIMATE
}

// ============================================
// Planning Process State (1:1 with Property)
// ============================================

model PlanningProcessState {
  id                 String   @id @default(uuid())
  propertyId         String   @unique @map("property_id")
  stateType          String   @map("state_type")
  developerName      String?  @map("developer_name")
  projectedSizeAfter String?  @map("projected_size_after")
  lastUpdateDate     DateTime @map("last_update_date")
  notes              String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("planning_process_states")
}

// ============================================
// Utility Info (1:1 with Property)
// ============================================

model UtilityInfo {
  id                       String  @id @default(uuid())
  propertyId               String  @unique @map("property_id")
  arnonaAccountNumber      String? @map("arnona_account_number")
  electricityAccountNumber String? @map("electricity_account_number")
  waterAccountNumber       String? @map("water_account_number")
  vaadBayitName            String? @map("vaad_bayit_name")
  waterMeterNumber         String? @map("water_meter_number")
  electricityMeterNumber   String? @map("electricity_meter_number")
  notes                    String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("utility_info")
}

// ============================================
// Ownership (M:N junction: Owner ↔ Property)
// ============================================

model Ownership {
  id                  String        @id @default(uuid())
  propertyId          String        @map("property_id")
  personId            String        @map("person_id")
  ownershipPercentage Decimal       @map("ownership_percentage") @db.Decimal(5, 2)
  ownershipType       OwnershipType @map("ownership_type")
  managementFee       Decimal?      @map("management_fee") @db.Decimal(10, 2)
  familyDivision      Boolean       @default(false) @map("family_division")
  startDate           DateTime      @map("start_date")
  endDate             DateTime?     @map("end_date")
  notes               String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  person   Person   @relation(fields: [personId], references: [id], onDelete: Restrict)

  @@index([propertyId])
  @@index([personId])
  @@index([deletedAt])
  @@map("ownerships")
}

enum OwnershipType {
  REAL
  LEGAL
}

// ============================================
// Mortgage
// ============================================

model Mortgage {
  id                    String   @id @default(uuid())
  propertyId            String?  @map("property_id") // nullable - NULL if loan
  bank                  String
  loanAmount            Decimal  @map("loan_amount") @db.Decimal(12, 2)
  interestRate          Decimal? @map("interest_rate") @db.Decimal(5, 2)
  monthlyPayment        Decimal? @map("monthly_payment") @db.Decimal(10, 2)
  earlyRepaymentPenalty Decimal? @map("early_repayment_penalty") @db.Decimal(10, 2)

  bankAccountId   String? @map("bank_account_id")
  mortgageOwnerId String? @map("mortgage_owner_id") // nullable - NULL if loan
  payerId         String  @map("payer_id") // FK to Person

  startDate        DateTime       @map("start_date")
  endDate          DateTime?      @map("end_date")
  status           MortgageStatus
  linkedProperties String[]       @map("linked_properties")

  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  property      Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  mortgageOwner Person?      @relation("MortgageOwner", fields: [mortgageOwnerId], references: [id], onDelete: SetNull)
  payer         Person       @relation("MortgagePayer", fields: [payerId], references: [id], onDelete: Restrict)

  @@index([propertyId])
  @@index([status])
  @@index([bank])
  @@index([bankAccountId])
  @@index([mortgageOwnerId])
  @@index([payerId])
  @@index([deletedAt])
  @@map("mortgages")
}

enum MortgageStatus {
  ACTIVE
  PAID_OFF
  REFINANCED
  DEFAULTED
}

// ============================================
// Rental Agreement (Property + Person as tenant)
// ============================================

model RentalAgreement {
  id                   String                @id @default(uuid())
  propertyId           String                @map("property_id")
  tenantId             String                @map("tenant_id") // FK to Person
  monthlyRent          Decimal               @map("monthly_rent") @db.Decimal(10, 2)
  startDate            DateTime              @map("start_date")
  endDate              DateTime              @map("end_date")
  status               RentalAgreementStatus
  hasExtensionOption   Boolean               @default(false) @map("has_extension_option")
  extensionUntilDate   DateTime?             @map("extension_until_date")
  extensionMonthlyRent Decimal?              @map("extension_monthly_rent") @db.Decimal(10, 2)

  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  property       Property        @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  tenant         Person          @relation("RentalTenant", fields: [tenantId], references: [id], onDelete: Restrict)
  propertyEvents PropertyEvent[]

  @@index([propertyId])
  @@index([tenantId])
  @@index([status])
  @@index([endDate])
  @@index([deletedAt])
  @@map("rental_agreements")
}

enum RentalAgreementStatus {
  FUTURE
  ACTIVE
  EXPIRED
  TERMINATED
}

// ============================================
// Property Event (Single Table Inheritance - 4 types)
// ============================================

model PropertyEvent {
  id             String            @id @default(uuid())
  propertyId     String            @map("property_id")
  eventType      PropertyEventType @map("event_type")
  eventDate      DateTime          @map("event_date")
  description    String?
  estimatedValue Decimal?          @map("estimated_value") @db.Decimal(12, 2)
  estimatedRent  Decimal?          @map("estimated_rent") @db.Decimal(10, 2)

  // PlanningProcessEvent fields
  planningStage      String? @map("planning_stage")
  developerName      String? @map("developer_name")
  projectedSizeAfter String? @map("projected_size_after")

  // PropertyDamageEvent fields (separate from ExpenseEvent)
  damageType          String?  @map("damage_type")
  estimatedDamageCost Decimal? @map("estimated_damage_cost") @db.Decimal(10, 2)
  expenseId           String?  @map("expense_id") // FK optional - link to ExpenseEvent

  // ExpenseEvent fields
  expenseType          ExpenseEventType? @map("expense_type")
  amount               Decimal?          @db.Decimal(10, 2)
  paidToAccountId      String?           @map("paid_to_account_id")
  affectsPropertyValue Boolean?          @map("affects_property_value")

  // RentalPaymentRequestEvent fields
  rentalAgreementId String?              @map("rental_agreement_id")
  month             Int?
  year              Int?
  amountDue         Decimal?             @map("amount_due") @db.Decimal(10, 2)
  paymentDate       DateTime?            @map("payment_date")
  paymentStatus     RentalPaymentStatus? @map("payment_status")

  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  property            Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  rentalAgreement     RentalAgreement? @relation(fields: [rentalAgreementId], references: [id], onDelete: SetNull)
  paidToAccount       BankAccount?     @relation(fields: [paidToAccountId], references: [id], onDelete: SetNull)
  linkedExpense       PropertyEvent?   @relation("ExpenseLink", fields: [expenseId], references: [id], onDelete: SetNull)
  expenseLinkedEvents PropertyEvent[]  @relation("ExpenseLink")

  @@unique([rentalAgreementId, month, year])
  @@index([propertyId])
  @@index([eventType])
  @@index([eventDate])
  @@index([deletedAt])
  @@map("property_events")
}

enum PropertyEventType {
  PlanningProcessEvent
  PropertyDamageEvent
  ExpenseEvent
  RentalPaymentRequestEvent
}

enum ExpenseEventType {
  MANAGEMENT_FEE
  REPAIRS
  MAINTENANCE
  TAX
  INSURANCE
  UTILITIES
  OTHER
}

enum RentalPaymentStatus {
  PENDING
  PAID
  OVERDUE
}
